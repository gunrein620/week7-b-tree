#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "${script_dir}" && pwd)
uname_s=$(uname -s 2>/dev/null || echo unknown)

case "${OS:-}:${OSTYPE:-}:${uname_s}" in
    Windows_NT:*:*|*:msys*:*|*:cygwin*:*|*:*:MINGW*|*:*:MSYS*)
        bin_rel="sqlengine.exe"
        ;;
    *)
        bin_rel="sqlengine.bin"
        ;;
esac

if ! make -C "${repo_root}" -q "${bin_rel}" 2>/dev/null; then
    make -C "${repo_root}" "${bin_rel}"
fi

exec "${repo_root}/${bin_rel}" "$@"
